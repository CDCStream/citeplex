# Copy to .env and fill in values (never commit .env)

NEXT_PUBLIC_APP_URL=https://www.citeplex.io

# Google Search Console — HTML tag verification `content` (layout metadata)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 (gtag; loads after cookie consent)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads — global site tag ID (same as in Ads → tag setup, format AW-XXXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads conversion `send_to` strings (Goals → Conversions → tag details)
# NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_SEND_TO=AW-XXXXXXXXXX/YYYYYYYYYY
# NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_SEND_TO=AW-XXXXXXXXXX/ZZZZZZZZZZ

# Supabase — production: custom domain (OAuth shows citeplex.io). Fallback: *.supabase.co still works.
NEXT_PUBLIC_SUPABASE_URL=https://auth.citeplex.io
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (API routes, webhooks)
SUPABASE_SERVICE_ROLE_KEY=

# Outrank → POST /api/outrank/webhook (shared secret; leave empty to skip auth in dev only)
OUTRANK_WEBHOOK_SECRET=

# Optional: POST /api/blog/save (header x-admin-secret)
BLOG_ADMIN_SECRET=

# Optional: default byline when Outrank omits author
BLOG_DEFAULT_AUTHOR=Citeplex Team

# Ahrefs API v3 — keyword volume & difficulty data
AHREFS_API_KEY=

# Anthropic API — Claude Sonnet (insights) & Claude Opus (article writing)
ANTHROPIC_API_KEY=
